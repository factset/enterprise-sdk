          },
          "code": {
            "description": "Error code identifying the type of error",
            "type": "string",
            "example": "parameterError"
          },
          "title": {
            "description": "Short human-readable summary of the error",
            "type": "string",
            "example": "Generic request error"
          },
          "detail": {
            "description": "Detailed human-readable explanation of this specific error occurrence",
            "type": "string",
            "example": "Authorization required"
          },
          "timestamp": {
            "description": "ISO 8601 formatted timestamp when the error occurred",
            "type": "string",
            "format": "date-time",
            "example": "2025-12-15T07:15:30.131Z"
          }
        },
        "required": [
          "id",
          "code",
          "title",
          "detail",
          "timestamp"
        ]
