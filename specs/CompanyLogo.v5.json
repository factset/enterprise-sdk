              "medium",
              "large",
              "vector",
              "custom"
            ]
          },
          "mimeType": {
            "nullable": true,
            "description": "Mime type of the logo.",
            "type": "string",
            "example": "image/png"
          },
          "url": {
            "nullable": true,
            "description": "URL of the logo.",
            "type": "string",
            "format": "url",
            "example": "https://logos.factset.com/111213/2025/2/4474af02-261f-5645-ae4c-bbcdd643798a/99624_1_7.png?Expires=1764444941&Key-Pair-Id=KD5OMB71J2Q9G&Signature=KYKEjQ6RBv7TarSI2FfFgMAyP0KkeUXqe7LTMA45Rzar8lWdo2V-5By7iD6OAb2-LhJPLXoA~l0vdgxL4OCOfy7~~2yORSHtw59tV-EYdycx5G016kIIEJfBII1F5Af5T9L87QE~9CF74-Pd7IRBLBRWu8PBsoscJd52aPxZYiIqig8THSwDpukxKSMPDL06E7DVawQQpvEMaqDjZS5HY8dhPGkcm8Ef2I7O9Ttt7p6-RJ2kYo8gK-10iUsNo6cSD62E5IMM4bwEeqRPCXy80twENBedFMWv9hLR4yjr~W~Pypp7Gm-ID~krXGnw95uCMGoU2TXzaiXI6KUkfK6Plw__"
          }
        },
        "description": "Company logos that satisfy the request parameters."
      },
      "CompanyLogoItemObject": {
        "type": "object",
        "nullable": false,
        "properties": {
          "idInstrument": {
            "nullable": true,
            "type": "string",
            "format": "id64",
            "description": "MDG identifier of the instrument.",
            "example": "209485"
          },
          "sourceIdentifier": {
            "nullable": true,
            "type": "string",
            "description": "Identifier used in the request.",
            "example": "FDS-US"
          },
          "logos": {
            "nullable": false,
            "description": "Company logos that satisfy the request parameters.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CompanyLogoObject"
            }
          }
        },
        "description": "List of company logos."
      },
      "AttributesMember": {
        "type": "array",
        "description": "Limit the attributes returned in the response to the specified set.",
        "items": {
          "type": "string",
          "maxLength": 100
        },
        "maxItems": 100,
        "uniqueItems": true,
        "example": []
      },
      "StatusObject": {
        "type": "object",
        "properties": {
          "code": {
            "type": "number",
            "format": "int32",
            "description": "The HTTP status code of the response, mirroring the code from the Status-Line of the HTTP response message (see [RFC2616] section 6.1)."
          }
        },
        "description": "The status member contains the status code of the response."
      },
      "PostCompanyLogoRequest": {
        "description": "Request Body",
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "description": "The data member contains the request's primary data.",
            "properties": {
              "identifier": {
                "type": "object",
                "description": "Set of identifiers and their type.",
                "properties": {
                  "values": {
                    "description": "Set of identifiers to resolve. ***values*** limit = 100 per request.\n",
                    "type": "array",
                    "nullable": false,
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "exclusiveMinimum": false,
                      "maxLength": 50,
                      "exclusiveMaximum": false,
                      "minimum": 1,
                      "maximum": 1,
                      "example": "FDS-US",
                      "pattern": "^[B-DF-HJ-NP-TV-Z0-9]{6}-[SLR]$|^[A-Z0-9.#&*+]{1,47}-[A-Z0-9]{2,4}$|^[0-9]{3,20}$|^[B-DF-HJ-NP-TV-Z0-9]{6}[0-9]$|^[A-Z]{2}[A-Z0-9]{9}[0-9]$|^[A-Z1-9][A-Z0-9]{5}$|^[0-9]{1,9}$|^[A-Z0-9]{8}[0-9]$|^[-A-Za-z0-9.#:]{1,25}$"
                    },
                    "uniqueItems": true,
                    "minItems": 1,
                    "maxItems": 100,
                    "example": [
                      "FDS-US"
                    ]
                  },
                  "type": {
                    "type": "string",
                    "example": "tickerRegion",
                    "description": "Type of the identifier. Accepted values types include:\n * **idInstrument** - MDG identifier of an instrument.\n * **idNotation** - MDG identifier of a listing.\n * **fdsPermanentIdentifierSecurity** - FactSet Permanent Identifier on security level.\n * **fdsPermanentIdentifierListing** - FactSet Permanent Identifier on listing level.\n * **fdsPermanentIdentifierRegional** - Regional FactSet Permanent Identifier.\n * **tickerExchange** - FactSet market symbol of a listing.\n * **tickerRegion** - Regional FactSet ticker symbol.\n * **sedol** - SEDOL or IDII of a listing.\n * **isin** - ISIN of an instrument.\n * **wkn** - WKN of an instrument.\n * **valor** - Valor number of an instrument.\n * **cusip** - CUSIP or CINS identifier of an instrument\n * **symbol** - Symbol of a listing\n",
                    "enum": [
                      "idInstrument",
                      "idNotation",
                      "fdsPermanentIdentifierSecurity",
                      "fdsPermanentIdentifierListing",
                      "fdsPermanentIdentifierRegional",
                      "tickerExchange",
                      "tickerRegion",
                      "sedol",
                      "isin",
                      "wkn",
                      "valor",
                      "cusip",
                      "symbol"
                    ]
                  }
                },
                "required": [
                  "values",
                  "type"
                ]
              },
              "format": {
                "type": "string",
                "description": "Format of the logo. If no format is defined all available formats are returned. Accepted formats are:\n * **rectangular** - Logos in rectangular format.\n * **square** - Logos in square format.\n",
                "default": "rectangular",
                "enum": [
                  "rectangular",
                  "square"
                ]
              },
              "size": {
                "description": "Standard or custom-size for the logo. Either a predefined size from the available options must be selected, or a custom size in pixels must be provided.",
                "type": "object",
                "properties": {
                  "predefined": {
                    "description": "Set of predefined sizes for logos. Accepted sizes are:\n * **small** - Rectangular logo maximum width of 88 pixels and maximum height of 31 pixels. Square logo 31 x 31 pixels.\n * **medium** - Small logo scaled up by 200%.\n * **large** - Small logo scaled up by 300%.\n * **vector** - Can be rendered at any size.\n",
                    "type": "array",
                    "nullable": false,
                    "items": {
                      "type": "string",
                      "enum": [
                        "small",
                        "medium",
                        "large",
                        "vector"
                      ]
                    },
                    "uniqueItems": true
                  },
                  "custom": {
                    "description": "Custom pixel-based size for the logo. Custom-sized logos are downscaled when possible; otherwise upscaled from the size-wise closest available logo. Regardless of the selected pixel width and height, the aspect ratio of the original logo is preserved without distortion.\n",
                    "type": "object",
                    "properties": {
                      "width": {
                        "description": "Width of the logo in pixels.",
                        "type": "number",
                        "format": "int32",
                        "minimum": 10,
                        "exclusiveMinimum": false,
                        "maximum": 200,
                        "exclusiveMaximum": false
                      },
                      "height": {
                        "description": "Height of the logo in pixels.",
                        "type": "number",
                        "format": "int32",
                        "minimum": 10,
                        "exclusiveMinimum": false,
                        "maximum": 200,
                        "exclusiveMaximum": false
                      }
                    },
                    "required": [
                      "width",
                      "height"
                    ]
                  }
                }
              },
              "mimeType": {
                "description": "Mime type of the logo. Accepted mime types are:\n* **image/png** - PNG compressed image.\n* **image/svg+xml** - Scalable Vector Graphics (SVG).\n",
                "type": "string",
                "enum": [
                  "image/png",
                  "image/svg+xml"
                ]
              }
            },
            "required": [
              "identifier",
              "size"
            ]
          },
          "meta": {
            "type": "object",
            "description": "The meta member contains the meta information of the request.",
            "properties": {
              "attributes": {
                "$ref": "#/components/schemas/AttributesMember"
              }
            }
          }
        }
      },
